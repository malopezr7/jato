---
import ChatWizard from "./ChatWizard.tsx";
---

<section id="skill" class="py-20 px-8 bg-rig-bg-alt transition-colors">
  <div class="max-w-[900px] mx-auto">
    <div class="fade-in">
      <div class="section-label">The superpower</div>
    </div>
    <div class="fade-in" style="transition-delay: 0.05s">
      <h2 class="section-title">
        Your AI builds your rig<br /><span class="section-muted">through conversation.</span>
      </h2>
    </div>
    <div class="fade-in" style="transition-delay: 0.1s">
      <p class="text-base text-rig-text-muted leading-relaxed max-w-[520px] mb-12">
        rig installs a skill that teaches your LLM how to create, modify, and manage your entire
        setup. Describe what you need — it writes the configs, generates the skills, picks the right
        MCPs.
      </p>
    </div>
    <div class="fade-in flex justify-center" style="transition-delay: 0.2s">
      <ChatWizard client:visible />
    </div>
  </div>
</section>

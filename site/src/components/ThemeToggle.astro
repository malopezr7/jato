---

<button
  id="theme-toggle"
  aria-label="Toggle theme"
  class="relative w-[50px] h-7 rounded-full border-none cursor-pointer p-0 flex-shrink-0"
  style="background: var(--toggle-bg); transition: background 0.3s"
>
  <div
    id="toggle-knob"
    class="absolute top-[3px] w-[22px] h-[22px] rounded-full flex items-center justify-center text-xs shadow-sm transition-[left] duration-250"
    style="background: var(--toggle-knob); left: 3px"
  >
    <span id="toggle-icon" class="leading-none">☀️</span>
  </div>
</button>

<script>
  const toggle = document.getElementById("theme-toggle");
  const knob = document.getElementById("toggle-knob");
  const icon = document.getElementById("toggle-icon");

  function updateKnob() {
    const isDark = document.documentElement.classList.contains("dark");
    if (knob) knob.style.left = isDark ? "25px" : "3px";
    if (icon) icon.textContent = isDark ? "🌙" : "☀️";
  }

  updateKnob();

  toggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("rig-theme", isDark ? "dark" : "light");
    updateKnob();
  });
</script>

<section class="py-24 pb-28 px-8 text-center">
  <div class="fade-in">
    <h2
      class="text-[clamp(28px,5vw,44px)] font-light -tracking-[1px] mb-4 leading-tight text-rig-text"
    >
      Stop configuring.<br />Start building.
    </h2>
  </div>
  <div class="fade-in" style="transition-delay: 0.1s">
    <p class="text-base text-rig-text-faint mb-9">
      Open source. MIT licensed. Let your AI do the setup.
    </p>
  </div>
  <div class="fade-in" style="transition-delay: 0.2s">
    <div class="flex gap-3 justify-center flex-wrap">
      <a
        href="https://github.com/malopezr7/rig"
        target="_blank"
        rel="noopener"
        class="font-mono text-sm bg-rig-btn-bg text-rig-btn-text px-7 py-3 rounded-lg no-underline border border-rig-btn-bg hover:bg-rig-btn-hover transition-colors"
      >
        View on GitHub
      </a>
      <div
        class="font-mono text-sm text-rig-btn-outline-text px-7 py-3 rounded-lg border border-rig-btn-outline-border select-all cursor-text transition-colors"
      >
        npx rig init
      </div>
    </div>
  </div>
</section>

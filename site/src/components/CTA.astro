---
---

<section class="py-24 pb-28 px-8 text-center">
  <div class="fade-in">
    <h2
      class="text-[clamp(28px,5vw,44px)] font-light -tracking-[1px] mb-4 leading-tight text-rig-text"
    >
      Stop configuring.<br />Start building.
    </h2>
  </div>
  <div class="fade-in" style="transition-delay: 0.1s">
    <p class="text-base text-rig-text-faint mb-9">
      Open source. MIT licensed. Let your AI do the setup.
    </p>
  </div>
  <div class="fade-in" style="transition-delay: 0.2s">
    <div class="flex gap-3 justify-center flex-wrap">
      <a
        href="https://github.com/malopezr7/rig"
        target="_blank"
        rel="noopener"
        class="font-mono text-sm bg-rig-btn-bg text-rig-btn-text px-7 py-3 rounded-lg no-underline border border-rig-btn-bg hover:bg-rig-btn-hover transition-colors"
      >
        View on GitHub
      </a>
      <div
        class="font-mono text-sm text-rig-btn-outline-text pl-7 pr-4 py-3 rounded-lg border border-rig-btn-outline-border transition-colors flex items-center gap-3"
      >
        <code class="select-all">npx rig init</code>
        <button
          onclick="navigator.clipboard.writeText('npx rig init')"
          aria-label="Copy"
          class="text-emerald-500 hover:text-emerald-400 transition-colors cursor-pointer bg-transparent border-none p-0"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

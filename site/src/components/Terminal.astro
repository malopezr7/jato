---
interface Props {
  title?: string;
}
const { title = "Terminal" } = Astro.props;
---

<div
  class="bg-rig-surface border border-rig-border rounded-xl overflow-hidden font-mono text-[13.5px] leading-[1.7] max-w-[640px] transition-colors"
>
  <div
    class="px-4 py-2.5 border-b border-rig-border flex items-center gap-2"
  >
    <div class="flex gap-1.5">
      <div class="w-2.5 h-2.5 rounded-full bg-rig-term-dot transition-colors"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-rig-term-dot transition-colors"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-rig-term-dot transition-colors"></div>
    </div>
    <span class="text-rig-text-ghost text-[11px] font-sans ml-2">{title}</span>
  </div>
  <div class="p-5 px-6 flex flex-col gap-3.5">
    <slot />
  </div>
</div>
